# Primary domain Traefik will serve (required)
DOMAIN=zellij.example.com

# Additional domains/IPs to accept, comma-separated (optional)
# Useful for LAN access via IP or alternate hostnames
# EXTRA_DOMAINS=192.168.1.100,fenrir.lan
EXTRA_DOMAINS=

# Ports exposed on the host (defaults: 80, 443)
HTTP_PORT=80
HTTPS_PORT=443

# Let's Encrypt — only needed when using the LE cert resolver
ACME_EMAIL=you@example.com

# Telegram alerting (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Generic webhook URLs — comma-separated (optional)
# WEBHOOK_URLS=https://hooks.example.com/zellij,https://other.example.com/hook
WEBHOOK_URLS=
